{
  "name": "chaveiro-system",
  "version": "1.0.38",
  "description": "Sistema de Gestao para Chaveiro",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "electron": "electron electron/main.js",
    "electron:dev": "cross-env NODE_ENV=development electron electron/main.js",
    "build": "electron-builder --win --publish always",
    "build:linux": "electron-builder --linux --publish always",
    "build:mac": "electron-builder --mac --publish always",
    "build:local": "electron-builder --win --publish never",
    "release": "electron-builder --publish always"
  },
  "keywords": [],
  "author": "tvsxgames",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.0",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "electron-updater": "^6.8.3",
    "expo-server-sdk": "^6.1.0",
    "express": "^5.2.1",
    "firebase-admin": "^13.9.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "node-forge": "^1.4.0",
    "pdfkit": "^0.17.2",
    "qrcode": "^1.5.4",
    "whatsapp-web.js": "^1.34.6",
    "xml-crypto": "^6.1.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.chaveiro.system",
    "productName": "Sistema Chaveiro",
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "copyright": "Copyright © 2025 Chaveiro System",
    "asar": false,
    "npmRebuild": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "package.json",
      "node_modules/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*",
      "!dist/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/icon.ico",
      "artifactName": "SistemaChaveiro-Setup.exe"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "electron/icon.png",
      "category": "Office"
    },
    "mac": {
      "target": "dmg",
      "icon": "electron/icon.icns"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "electron/icon.ico",
      "installerHeaderIcon": "electron/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Sistema Chaveiro"
    },
    "publish": {
      "provider": "github",
      "owner": "reidaschavesbc",
      "repo": "chaveiro-system",
      "private": true
    }
  }
}
